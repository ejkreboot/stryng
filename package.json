{
  "name": "stryng",
  "version": "0.1.0",
  "author": "Eric J. Kort",
  "license": "MIT (see LICENSE file)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --sourcemap",
    "dev": "tsup src/index.ts --dts --format esm --watch",
    "watch": "tsup src/index.ts --dts --format esm --watch",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "release": "npm run clean && npm run build && npm publish --access public",
    "demo": "npm --workspace demo run dev"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.75.1",
    "eslint": "^9.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "watch": "^1.0.2",
    "y-indexeddb": "^9.0.12",
    "y-webrtc": "^10.3.0",
    "y-websocket": "^3.0.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "y-webrtc": "^10.6.0",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "y-webrtc": {
      "optional": true
    },
    "y-websocket": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-diff": "^1.3.0"
  }
}
